NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
SUPABASE_SECRET_KEY="your-supabase-secret-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

POSTGRES_HOST="db.your-project-ref.supabase.co"
POSTGRES_DATABASE="postgres"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-postgres-password"
POSTGRES_URL="postgres://postgres.your-project-ref:your-postgres-password@aws-1-region.pooler.supabase.com:6543/postgres?sslmode=require"
POSTGRES_PRISMA_URL="postgres://postgres.your-project-ref:your-postgres-password@aws-1-region.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgres://postgres.your-project-ref:your-postgres-password@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=require"
